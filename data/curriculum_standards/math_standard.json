{
  "subject": "数学",
  "standard": "义务教育数学课程标准（2022年版）",
  "level": "初中",
  "core_competencies": [
    "数学抽象",
    "逻辑推理",
    "数学建模",
    "直观想象",
    "数学运算",
    "数据分析"
  ],
  "grade_requirements": {
    "七年级": {
      "topics": [
        {
          "name": "有理数",
          "objectives": ["理解有理数的意义", "掌握有理数运算法则", "能进行有理数的混合运算"],
          "key_competencies": ["数学运算", "数学抽象"]
        },
        {
          "name": "代数式",
          "objectives": ["理解代数式概念", "掌握整式的加减运算", "理解合并同类项"],
          "key_competencies": ["数学抽象", "数学运算"]
        },
        {
          "name": "一元一次方程",
          "objectives": ["理解等式性质", "掌握一元一次方程的解法", "能用方程解决实际问题"],
          "key_competencies": ["数学建模", "数学运算"]
        },
        {
          "name": "线段与角",
          "objectives": ["理解线段和角的基本性质", "掌握度量方法"],
          "key_competencies": ["直观想象", "数学运算"]
        },
        {
          "name": "三角形",
          "objectives": ["理解三角形分类", "掌握三角形三边关系", "理解内角和定理"],
          "key_competencies": ["直观想象", "逻辑推理"]
        }
      ]
    },
    "八年级": {
      "topics": [
        {
          "name": "因式分解",
          "objectives": ["掌握提公因式法", "掌握公式法", "能综合运用因式分解"],
          "key_competencies": ["数学运算", "逻辑推理"]
        },
        {
          "name": "一元二次方程",
          "objectives": ["理解一元二次方程概念", "掌握求根公式法、因式分解法、配方法", "能应用方程解决实际问题"],
          "key_competencies": ["数学运算", "数学建模"]
        },
        {
          "name": "勾股定理",
          "objectives": ["理解勾股定理及其逆定理", "能用勾股定理解决计算问题", "了解勾股定理的证明"],
          "key_competencies": ["逻辑推理", "直观想象"]
        },
        {
          "name": "一次函数",
          "objectives": ["理解函数概念", "掌握一次函数图像和性质", "能用一次函数解决实际问题"],
          "key_competencies": ["数学建模", "数学抽象"]
        },
        {
          "name": "全等三角形",
          "objectives": ["理解全等三角形性质", "掌握SSS、SAS、ASA、AAS判定方法"],
          "key_competencies": ["逻辑推理", "直观想象"]
        }
      ]
    },
    "九年级": {
      "topics": [
        {
          "name": "二次函数",
          "objectives": ["掌握二次函数图像和性质", "理解顶点式和一般式的转化", "能解决最值问题"],
          "key_competencies": ["数学抽象", "数学建模", "数学运算"]
        },
        {
          "name": "相似三角形",
          "objectives": ["理解相似三角形判定", "掌握相似比", "能应用相似解决问题"],
          "key_competencies": ["逻辑推理", "直观想象"]
        },
        {
          "name": "圆",
          "objectives": ["理解圆的基本性质", "掌握圆与直线的位置关系", "能计算弧长和扇形面积"],
          "key_competencies": ["直观想象", "数学运算"]
        },
        {
          "name": "概率初步",
          "objectives": ["理解概率意义", "掌握简单事件概率计算", "了解频率与概率的关系"],
          "key_competencies": ["数据分析", "数学建模"]
        }
      ]
    }
  }
}
